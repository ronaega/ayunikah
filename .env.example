# Optional Supabase configuration for production persistence.
# The current app runs with local demo data until these are connected.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional OpenAI provider key for the assistant endpoint in src/app/api/ai/route.ts.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
